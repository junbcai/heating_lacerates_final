sphk <- tribble(
~sample,~group,~run,~target,~ref,
# run1 empty
"E6","Empty","run1",mean(c(31.79,31.51)),mean(c(24.71,24.64)),
"E7","Empty","run1",mean(c(31.06,30.64,30.70)),mean(c(24.35,24.41,24.40)),
"E8","Empty","run1",mean(c(31.20,31.14,30.90)),mean(c(25.06,25.03,25.04)),
# run1 KD
"S6","KD","run1",mean(c(31.41,30.70,30.91)),mean(c(24.28,24.09,24.09)),
"S7","KD","run1",mean(c(32.98,31.89,31.75)),mean(c(23.64,23.55,23.55)),
"S8","KD","run1",mean(c(33.66,34.18,33.60)),mean(c(24.39,24.35,24.37)),
# run2 empty
"E6","Empty","run2",mean(c(31.48,31.56,31.93)),mean(c(24.31,24.15,24.64)),
"E7","Empty","run2",mean(c(32.23,31.68,32.67)),mean(c(24.98,25.21,25.69)),
"E8","Empty","run2",mean(c(32.10,32.05,31.62)),mean(c(25.81,25.67,25.83)),
# run2 KD
"S6","KD","run2",mean(c(32.23,32.26,33.27)),mean(c(25.17,25.27,25.29)),
"S7","KD","run2",mean(c(33.39,33.76,33.62)),mean(c(25.34,24.86,24.78)),
"S8","KD","run2",mean(c(35.09,35.99,35.51)),mean(c(25.75,25.52,25.79))
)
# ΔCt per run
sphk <- sphk %>%
mutate(dCt = target - ref)
# Average the two runs
sphk_avg <- sphk %>%
group_by(sample,group) %>%
summarise(dCt = mean(dCt), .groups="drop") %>%
mutate(gene="SPHK")
# -----------------------------
# OTHER GENES (from earlier)
# -----------------------------
