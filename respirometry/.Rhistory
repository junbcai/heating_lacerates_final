) %>%
mutate(dCt = target - ref) %>%
select(gene,group,sample,dCt)
# combine datasets
df <- bind_rows(other, sphk_avg)
# -----------------------------
# Calculate ΔΔCt
# -----------------------------
df <- df %>%
group_by(gene) %>%
mutate(control_mean = mean(dCt[group=="Empty"]),
ddCt = dCt - control_mean,
fold_change = 2^(-ddCt))
# -----------------------------
# Boxplot with biological replicates
# -----------------------------
summary_kd <- df %>%
filter(group == "KD") %>%
group_by(gene) %>%
summarise(
mean_fc = mean(fold_change),
kd_percent = (1 - mean_fc) * 100
)
summary_kd <- summary_kd %>%
mutate(
label = paste0(round(kd_percent,1), "% KD"),
y_pos = max(df$fold_change) * 1.1
)
ggplot(df, aes(x=group,y=fold_change,fill=group))+
geom_boxplot(outlier.shape=NA,alpha=0.7,width=0.6)+
geom_jitter(width=0.08,size=3)+
facet_wrap(~gene,nrow=1)+
geom_text(
data=summary_kd,
aes(x=2,y=2,label=label),
inherit.aes=FALSE,
size=5
)+
ylim(0, 2)+
theme_classic(base_size=15)+
scale_fill_manual(values=c("#56B4E9","#E69F00"))+
labs(
y="Fold Change (2^-ΔΔCt)",
x="",
title="RNAi knockdown vs empty vector controls"
)
library(dplyr)
stats <- df %>%
group_by(gene) %>%
summarise(
p_value = t.test(fold_change ~ group)$p.value
)
stats <- stats %>%
mutate(
signif = case_when(
p_value < 0.001 ~ "***",
p_value < 0.01  ~ "**",
p_value < 0.05  ~ "*",
TRUE ~ "ns"
)
)
stats <- stats %>%
mutate(y_pos = max(df$fold_change) * 1.05)
