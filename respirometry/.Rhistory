~gene,~group,~sample,~target,~ref,
# CerS5
"CerS5","KD","C1",mean(c(29.28,29.19,29.09)),mean(c(22.53,22.42,22.43)),
"CerS5","KD","C2",mean(c(29.95,30.08,29.69)),mean(c(23.79,23.76,23.74)),
