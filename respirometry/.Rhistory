"CerS5","Empty","E3",mean(c(27.69,27.66,27.75)),mean(c(22.56,22.59,22.60)),
# ACDase
"ACDase","KD","A1",mean(c(26.04,25.90,25.88,25.98)),mean(c(22.04,21.97,21.84,21.89)),
"ACDase","KD","A2",mean(c(27.04,26.63,26.67,26.66)),mean(c(22.51,22.41,22.44,22.67)),
"ACDase","KD","A3",mean(c(26.89,27.17,26.95,27.38)),mean(c(23.08,23.17,23.21,23.44)),
"ACDase","Empty","E1",mean(c(24.86,24.67,24.50)),mean(c(22.81,22.85,22.79)),
"ACDase","Empty","E2",mean(c(25.51,25.50,25.40)),mean(c(22.75,22.37,22.31)),
"ACDase","Empty","E3",mean(c(25.30,25.33,25.46)),mean(c(22.80,22.76,22.79)),
# LAMP1
"LAMP1","KD","L1",mean(c(25.06,24.86,24.88)),mean(c(23.18,23.18,22.99)),
"LAMP1","KD","L2",mean(c(24.99,25.21,24.87)),mean(c(22.38,22.46,22.45)),
"LAMP1","KD","L3",mean(c(24.02,24.05,24.09)),mean(c(22.28,22.17,22.14)),
"LAMP1","Empty","E1",mean(c(24.53,24.27,24.14)),mean(c(22.67,22.60,22.45)),
"LAMP1","Empty","E2",mean(c(23.97,23.82,23.82)),mean(c(22.19,22.16,22.05)),
